{
  "name": "barmibuddy-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace apps/mobile",
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "packageManager": "npm@10.0.0"
}
